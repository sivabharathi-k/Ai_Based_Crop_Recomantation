# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/crop_prediction

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Python ML Model Path
ML_MODEL_PATH=./ml_models/crop_recommendation_model.pkl
PYTHON_SCRIPT_PATH=./scripts/predict_crop.py

# Top-N crop recommendations from predict_proba (Python reads this env var)
TOP_N_PREDICTIONS=5

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# External APIs
WEATHER_API_KEY=your_weather_api_key
MARKET_API_KEY=your_market_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
FRONTEND_URL=http://localhost:3000

# Optional: plant disease CNN (defaults to ml_train/plant_disease_model.keras)
# PLANT_DISEASE_MODEL_PATH=../ml_train/plant_disease_model.keras
# PLANT_DISEASE_CLASSES_PATH=../ml_train/plant_disease_classes.json
# PLANT_DISEASE_REQUIRE_CNN=0
# IMG_SIZE=224
